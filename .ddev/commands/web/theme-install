#!/usr/bin/env bash

## Description: Install theme dependencies and build assets (mirrors Lando `ti`). Optionally pass a theme machine name; defaults to the configured theme. Pass "all" for every theme.
## Usage: theme-install [theme_name|all]
## Example: ddev theme-install
##          ddev theme-install jcc_md
##          ddev theme-install md     # jcc_ prefix added, installs jcc_base first
##          ddev theme-install all
## Aliases: theme:install,install-theme-tools,thi

# Abort if anything fails
set -e

#-------------------------- Helper functions --------------------------------

green='\033[0;32m'
yellow='\033[1;33m'
red='\033[0;31m'
NC='\033[0m'
divider='===================================================\n'

#-------------------------- Settings --------------------------------

DOCROOT="${DDEV_DOCROOT:-web}"
# Root directory that holds all custom themes (derived from the configured THEME).
THEMES_ROOT="/var/www/html/${DOCROOT}/$(dirname "${THEME:-themes/custom/jcc_base}")"
# All project themes are subthemes of this base theme and depend on its build.
BASE_THEME="jcc_base"

#-------------------------- Node setup -------------------------------------

# Set up NVM and select the theme's Node version from .nvmrc when present;
# otherwise fall back to the container's default Node.
setup_node() {
  local path="$1"
  export NVM_DIR="$HOME/.nvm"
  # nvm's auto-use hook can return non-zero (e.g. no default alias); relax
  # errexit while we source and switch Node so it can't abort the script.
  set +e
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1090
    source "$NVM_DIR/nvm.sh"
    if [ -f "$path/.nvmrc" ]; then
      echo -e "Using Node.js version from .nvmrc: $(cat "$path/.nvmrc")"
      (cd "$path" && nvm install) >/dev/null 2>&1
      (cd "$path" && nvm use) >/dev/null 2>&1
    fi
  fi
  set -e

  # Laravel Mix v4 / webpack 4 needs the legacy OpenSSL provider on Node >= 17.
  local node_major
  node_major="$(node -v 2>/dev/null | sed 's/v\([0-9]*\).*/\1/')"
  if [ -n "$node_major" ] && [ "$node_major" -ge 17 ]; then
    export NODE_OPTIONS=--openssl-legacy-provider
  fi
  echo -e "Node: $(node -v 2>/dev/null)"
}

#-------------------------- Install + build --------------------------------

install_theme() {
  local theme="$1"
  local path="${THEMES_ROOT}/${theme}"

  if [ ! -d "$path" ]; then
    echo -e "${red}Theme directory not found: ${path}${NC}"
    exit 1
  fi
  if [ ! -f "$path/package.json" ]; then
    echo -e "${yellow}No package.json in ${theme}, skipping.${NC}"
    return 0
  fi

  setup_node "$path"
  cd "$path"

  echo -e "🚧 ${yellow} Installing NPM dependencies for ${theme}. ${NC} 🚧"
  echo -e "${green}${divider}${NC}"
  # Prefer a reproducible install when a lockfile is present.
  if [ -f "package-lock.json" ]; then
    npm ci || npm install
  else
    npm install
  fi

  echo -e "🚧 ${yellow} Building production assets for ${theme}. ${NC} 🚧"
  echo -e "${green}${divider}${NC}"
  npm run production
}

#-------------------------- Execution -------------------------------------

THEME_ARG="${1:-}"

# Install + build every theme that has a package.json.
if [ "$THEME_ARG" = "all" ]; then
  echo -e "🚧 ${yellow} Installing ALL themes in ${THEMES_ROOT}. ${NC} 🚧"
  echo -e "${green}${divider}${NC}"
  for d in "${THEMES_ROOT}"/*/ ; do
    [ -f "${d}package.json" ] || continue
    install_theme "$(basename "$d")"
  done
  echo -e "🎉 ${yellow} All themes installed and built! ${NC} 🎉"
  echo -e "To start watching for file changes, run: ${yellow}ddev theme-watch [theme]${NC}"
  echo -e "${green}${divider}${NC}"
  exit 0
fi

# Resolve the target theme, defaulting to the configured theme.
THEME_NAME="${THEME_ARG:-${THEMENAME:-$(basename "${THEME:-themes/custom/jcc_base}")}}"

# Mirror Lando: a name without the jcc_ prefix gets it added, and the base
# theme is installed/built first since project themes depend on it.
if [[ "$THEME_NAME" != jcc_* ]]; then
  echo -e "${yellow}No jcc_ prefix detected. Installing ${BASE_THEME} first.${NC}"
  install_theme "$BASE_THEME"
  THEME_NAME="jcc_${THEME_NAME}"
fi

install_theme "$THEME_NAME"

echo -e "🎉 ${yellow} Theme setup complete for ${THEME_NAME}! ${NC} 🎉"
echo -e "To start watching for file changes, run: ${yellow}ddev theme-watch ${THEME_NAME}${NC}"
echo -e "${green}${divider}${NC}"
