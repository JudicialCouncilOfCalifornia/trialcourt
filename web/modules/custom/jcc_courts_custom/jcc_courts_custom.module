<?php

/**
 * @file
 * Module hooks for jcc_courts_custom.
 */

use Drupal\migrate\MigrateExecutable;
use Drupal\migrate\MigrateMessage;
use Drupal\migrate\Plugin\MigrationInterface;

/**
 * Citable opinions migration callback.
 */
function jcc_courts_custom_migrate_opinions_citable() {
  $migration_id = 'courts_node_opinion_published';
  jcc_courts_custom_run_migration($migration_id, TRUE);
}

/**
 * Citable opinions with grant review migration callback.
 */
function jcc_courts_custom_migrate_opinions_citable_review() {
  $migration_id = 'courts_node_opinion_published_review';
  jcc_courts_custom_run_migration($migration_id, TRUE);
}

