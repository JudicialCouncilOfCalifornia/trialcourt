 * Non-citable opinions migration callback.
 */
function jcc_courts_custom_migrate_opinions_noncitable() {
  $migration_id = 'courts_node_opinion_unpublished';
  jcc_courts_custom_run_migration($migration_id, TRUE);
}

/**
 * Non-citable opinions with grant review migration callback.
 */
