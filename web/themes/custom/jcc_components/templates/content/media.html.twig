<article{{ attributes }}>
  {{ title_suffix.contextual_links }}
  <figure class="overlay-caption">
    {% if content %}
      {{ content }}
    {% endif %}
    {% if content['#caption'] %}
      <figcaption>{{ content['#caption'] }}</figcaption>
    {% else %}
      <figcaption>The test media caption</figcaption>
    {% endif %}
  </figure>
</article>
